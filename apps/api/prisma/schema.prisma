generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  brand
  creator
  admin
}

enum Platform {
  instagram
  tiktok
  youtube
  ugc
}

enum Category {
  Fashion
  Beauty
  Travel
  Fitness
  Food
  Lifestyle
  Tech
  Gaming
  Music
  Family
  Comedy
  Pets
}

enum OrderStatus {
  pending_payment
  awaiting_creator
  in_progress
  submitted
  revision_requested
  approved
  released
  cancelled
  disputed
}

enum CampaignStatus {
  draft
  open
  closed
}

enum ApplicationStatus {
  pending
  accepted
  rejected
  withdrawn
}

enum NotificationKind {
  order_update
  new_message
  new_application
  payment
  system
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  name            String
  role            Role
  avatarUrl       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  emailVerifiedAt DateTime?
  bannedAt        DateTime?
  // Preferred UI locale. Drives notification copy + initial cookie on login.
  // Null means "follow the request" (Accept-Language / cookie / default).
  locale          String?

  brandProfile    BrandProfile?
  creatorProfile  CreatorProfile?
  refreshTokens   RefreshToken[]
  notifications   Notification[]
  savedCreators   SavedCreator[]
  reviewsLeft     Review[]         @relation("ReviewsLeft")
  threadsAsBrand  Thread[]         @relation("ThreadBrand")
  threadsAsCreator Thread[]        @relation("ThreadCreator")
  messages        Message[]
  campaigns       Campaign[]       @relation("CampaignBrand")
  ordersAsBrand   Order[]          @relation("OrderBrand")
}

model RefreshToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model BrandProfile {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String   @unique
  brandName   String
  website     String?
  industry    String?
  about       String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CreatorProfile {
  id              String         @id @default(cuid())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String         @unique
  username        String         @unique
  headline        String
  bio             String
  city            String
  country         String
  coverUrl        String?
  startingPrice   Int            @default(50)
  rating          Float          @default(5)
  reviewsCount    Int            @default(0)
  platforms       Platform[]
  categories      Category[]
  badges          String[]
  followersIg     Int?
  followersTt     Int?
  followersYt     Int?
  avgViews        Int?
  engagement      Float?
  audience        Json?
  portfolio       String[]
  isAvailable     Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  packages        Package[]
  savedBy         SavedCreator[]
  reviewsReceived Review[]       @relation("ReviewsReceived")
  applications    Application[]
  orders          Order[]        @relation("OrderCreator")
  threadsAsCreator Thread[]      @relation("ThreadCreatorProfile")

  @@index([username])
}

model Package {
  id           String         @id @default(cuid())
  creator      CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  title        String
  description  String?
  price        Int
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  orders       Order[]
  @@index([creatorId])
}

model SavedCreator {
  id        String         @id @default(cuid())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  creator   CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String
  createdAt DateTime       @default(now())

  @@unique([userId, creatorId])
}

model Campaign {
  id              String         @id @default(cuid())
  brand           User           @relation("CampaignBrand", fields: [brandId], references: [id], onDelete: Cascade)
  brandId         String
  title           String
  description     String
  budgetMin       Int
  budgetMax       Int
  platforms       Platform[]
  categories      Category[]
  creatorsNeeded  Int            @default(1)
  deadline        DateTime?
  status          CampaignStatus @default(open)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  applications    Application[]
  @@index([brandId, status])
}

model Application {
  id         String            @id @default(cuid())
  campaign   Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  creator    CreatorProfile    @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId  String
  price      Int
  pitch      String
  status     ApplicationStatus @default(pending)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([campaignId, creatorId])
  @@index([campaignId, status])
}

model Order {
  id           String       @id @default(cuid())
  brand        User         @relation("OrderBrand", fields: [brandId], references: [id], onDelete: Cascade)
  brandId      String
  creator      CreatorProfile @relation("OrderCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  package      Package      @relation(fields: [packageId], references: [id])
  packageId    String
  brief        String
  amount       Int
  serviceFee   Int          @default(0)
  status       OrderStatus  @default(pending_payment)
  deadline     DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  events       OrderEvent[]
  deliveries   Delivery[]
  review       Review?

  @@index([brandId, status])
  @@index([creatorId, status])
}

model OrderEvent {
  id        String      @id @default(cuid())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

model Delivery {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  url       String
  note      String?
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Review {
  id         String         @id @default(cuid())
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    String         @unique
  author     User           @relation("ReviewsLeft", fields: [authorId], references: [id])
  authorId   String
  creator    CreatorProfile @relation("ReviewsReceived", fields: [creatorId], references: [id])
  creatorId  String
  rating     Int
  text       String
  createdAt  DateTime       @default(now())

  @@index([creatorId])
}

model Thread {
  id              String          @id @default(cuid())
  brand           User            @relation("ThreadBrand", fields: [brandId], references: [id], onDelete: Cascade)
  brandId         String
  creator         User            @relation("ThreadCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  creatorUserId   String
  creatorProfile  CreatorProfile? @relation("ThreadCreatorProfile", fields: [creatorProfileId], references: [id])
  creatorProfileId String?
  lastMessageAt   DateTime        @default(now())
  createdAt       DateTime        @default(now())

  messages        Message[]
  @@unique([brandId, creatorUserId])
  @@index([brandId])
  @@index([creatorUserId])
}

model Message {
  id        String   @id @default(cuid())
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId  String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  kind      NotificationKind
  // Bilingual payload: { en: "...", ar: "..." } for system-generated copy.
  // Older single-language rows (legacy from before the bilingual switch) are
  // returned as-is and the service layer picks .en as fallback.
  title     Json
  body      Json?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}
