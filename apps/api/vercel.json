{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm prisma generate && pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/index" },
    { "source": "/api/v1", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" }
  ]
}
